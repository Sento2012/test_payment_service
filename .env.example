# Доступы/секреты — только через окружение.
# Прикладные параметры (prefetch, relay, retry, webhook, gateway) — в src/config/config.yaml.

# --- Postgres ---
POSTGRES_USER=payments
POSTGRES_PASSWORD=payments
POSTGRES_DB=payments

# --- App (доступы) ---
DATABASE_URL=postgresql+asyncpg://payments:payments@postgres:5432/payments
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
API_KEY=secret-api-key

# --- Traefik (наружу публикуется ТОЛЬКО он; порт можно сменить при конфликте) ---
TRAEFIK_HTTP_PORT=8088
